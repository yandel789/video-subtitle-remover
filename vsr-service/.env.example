# vsr-service 环境变量模板
# 用法：cp .env.example .env 然后填入真实凭据

# ===== 阿里云 OSS（结果上传用，必填）=====
ACCESSKEY_ID=
ACCESSKEY_SECRET=
OSS_REGION=oss-cn-shanghai
OSS_BUCKET=video-clean
OSS_ENDPOINT=https://oss-cn-shanghai.aliyuncs.com
OSS_RESULT_KEY_PREFIX=ai-output/

# ===== 服务端（可选，留空用默认值）=====
# VSR_PORT=3001
# VSR_HOST=0.0.0.0
# 处理视频的临时工作目录，默认 vsr-service/workspace
# VSR_WORKSPACE=/abs/path/to/workspace

# ===== VSR 处理默认参数（可选）=====
# sttn-auto / sttn-det / lama / propainter / opencv
# VSR_DEFAULT_INPAINT_MODE=sttn-det
# PP_OCRv5_MOBILE（快速）/ PP_OCRv5_SERVER（精准）
# VSR_DEFAULT_SUBTITLE_DETECT_MODE=PP_OCRv5_SERVER

# ===== 重试与超时（可选）=====
# OSS_RETRY_TIMES=3
# OSS_RETRY_BASE_SECONDS=1.0
# VSR_TASK_TIMEOUT_SECONDS=2400
